# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://nash-equilibrium-simulator.com/"

# Server Configuration
PORT=8080

# AUTH_SECRET: HMAC key used to sign auth session bearer tokens.
# REQUIRED in production — if unset, the server falls back to a random key
# generated at boot, which invalidates all existing sessions on every restart
# (users get logged out). Set a long, random, stable value (e.g. `openssl rand -hex 32`).
# SESSION_SECRET is accepted as an alias.
AUTH_SECRET="generate-with-openssl-rand-hex-32"

# ADMIN_SECRET: shared secret required (via the x-admin-secret header) to read
# the /api/admin/stats endpoint, which exposes per-user info. The endpoint fails
# closed: if ADMIN_SECRET is unset it returns 401 for everyone. Set a long,
# random value to enable it.
ADMIN_SECRET="generate-with-openssl-rand-hex-32"

# SMTP Configuration for sending actual verification emails:
# Leave unset to use free Ethereal sandbox (perfect for development - doesn't send real emails)
# Set these values to send REAL emails to users:

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password-here"
SMTP_FROM="Nash Equilibrium Simulator <your-email@gmail.com>"

# SMTP_ALLOW_INSECURE_TLS: set to "true" ONLY for local/dev relays with
# self-signed certs. It disables SMTP TLS certificate validation, which exposes
# credentials and mail to MITM — never enable in production.
# SMTP_ALLOW_INSECURE_TLS="false"
