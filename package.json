{
  "name": "react-example",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "node --experimental-strip-types server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "node dist/server.cjs",
    "clean": "rm -rf dist db.json",
    "lint": "tsc --noEmit",
    "electron:start": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "5.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.9",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.nashequilibrium.simulator",
    "productName": "Nash Equilibrium Simulator",
    "afterPack": "./afterPack.cjs",
    "directories": {
      "output": "dist-electron"
    },
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "icon": "build/icon.icns"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "db.json"
    ],
    "asar": true
  }
}
